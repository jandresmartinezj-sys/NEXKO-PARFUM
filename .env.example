# Copia este archivo a .env.local y rellena los valores reales.
SHOPIFY_STORE_DOMAIN=tu-tienda.myshopify.com
SHOPIFY_STOREFRONT_TOKEN=
SHOPIFY_ADMIN_TOKEN=
SHOPIFY_API_VERSION=2024-10
# Credenciales OAuth de la app (opcional; no las usa el seed)
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
NEXT_PUBLIC_WHATSAPP_NUMBER=573000000000
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Analítica (opcional — se cargan solo si tienen valor)
NEXT_PUBLIC_GA_ID=
NEXT_PUBLIC_META_PIXEL_ID=

# Revalidación on-demand (webhook de Shopify -> /api/revalidate?secret=...)
REVALIDATE_SECRET=
